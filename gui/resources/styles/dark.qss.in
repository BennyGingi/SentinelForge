/* dark.qss.in — generated by CMake from cmake/theme.cmake. Do not edit output. */

QWidget {
    background-color: @SF_BG_BASE@;
    color: @SF_TEXT_PRIMARY@;
    font-family: @SF_FONT_UI@;
    font-size: 13px;
}

/* Labels must not inherit the opaque QWidget fill — that paints dark bars inside chips/metrics. */
QLabel {
    background-color: transparent;
    border: none;
}

QFrame#Panel {
    background-color: @SF_BG_SURFACE@;
    border: 1px solid @SF_BORDER_SUBTLE@;
    border-radius: 6px;
}

QLabel#PanelTitle {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: @SF_TEXT_PRIMARY@;
    padding: 0 0 8px 0;
}

QLabel#MicroLabel {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: @SF_TEXT_SECONDARY@;
}

QLabel#MetricValue {
    font-family: @SF_FONT_MONO@;
    font-size: 22px;
    font-weight: 600;
    color: @SF_TEXT_PRIMARY@;
}

QLabel#HeroMetric {
    font-family: @SF_FONT_MONO@;
    font-size: 22px;
    font-weight: 600;
    color: @SF_TEXT_PRIMARY@;
    background: transparent;
    border: none;
}

QLabel#EmptyState {
    color: @SF_TEXT_MUTED@;
    font-size: 13px;
}

QLabel#ChipValue {
    font-family: @SF_FONT_MONO@;
    font-size: 14px;
    font-weight: 600;
    color: @SF_TEXT_PRIMARY@;
    background: transparent;
    border: none;
    padding: 0;
}

QLabel#MetricUnit {
    font-size: 11px;
    font-weight: 400;
    color: @SF_TEXT_MUTED@;
    background: transparent;
}

QFrame#StatusChip {
    background-color: @SF_BG_RAISED@;
    border: 1px solid @SF_BORDER_SUBTLE@;
    border-radius: 4px;
    padding: 0;
    max-height: 52px;
}

QFrame#StatusStrip {
    background-color: @SF_BG_BASE@;
    border: none;
    max-height: 52px;
}

QFrame#NavRail {
    background-color: @SF_BG_BASE@;
    border-right: 1px solid @SF_BORDER_SUBTLE@;
}

QFrame#InspectorPane {
    background-color: @SF_BG_INSET@;
    border-left: 1px solid @SF_BORDER_SUBTLE@;
}

QTableView {
    background-color: @SF_BG_SURFACE@;
    alternate-background-color: @SF_BG_SURFACE@;
    gridline-color: transparent;
    border: none;
    outline: none;
    selection-background-color: @SF_BG_RAISED@;
    selection-color: @SF_TEXT_PRIMARY@;
    font-size: 12px;
}
QTableView::item {
    padding: 8px 12px;
    border: none;
}
QTableView::item:hover {
    background-color: @SF_BG_RAISED@;
}
QTableView::item:focus {
    outline: 1px solid @SF_ACCENT@;
}

QHeaderView::section {
    background-color: @SF_BG_RAISED@;
    color: @SF_TEXT_SECONDARY@;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 12px;
    border: none;
    border-bottom: 1px solid @SF_BORDER_SUBTLE@;
}

QPlainTextEdit#LogViewer {
    background-color: @SF_BG_INSET@;
    border: 1px solid @SF_BORDER_SUBTLE@;
    border-radius: 6px;
    font-family: @SF_FONT_MONO@;
    font-size: 13px;
    color: @SF_TEXT_PRIMARY@;
    padding: 8px;
}

QToolButton#NavItem {
    background: transparent;
    border: none;
    border-left: 2px solid transparent;
    padding: 8px 10px;
    color: @SF_TEXT_MUTED@;
    text-align: left;
}
QToolButton#NavItem:hover {
    color: @SF_TEXT_SECONDARY@;
    background-color: @SF_BG_SURFACE@;
}
QToolButton#NavItem:checked {
    color: @SF_ACCENT@;
    border-left: 2px solid @SF_ACCENT@;
    background-color: @SF_BG_SURFACE@;
}
QToolButton#NavItem:focus {
    outline: 1px solid @SF_ACCENT@;
}

QComboBox {
    background-color: @SF_BG_RAISED@;
    border: 1px solid @SF_BORDER_SUBTLE@;
    border-radius: 4px;
    padding: 4px 8px;
    color: @SF_TEXT_SECONDARY@;
}
QComboBox:hover {
    border: 1px solid @SF_BORDER_STRONG@;
    color: @SF_TEXT_PRIMARY@;
}
QComboBox:focus,
QComboBox:on {
    border: 1px solid @SF_ACCENT@;
    color: @SF_TEXT_PRIMARY@;
}
QComboBox QAbstractItemView {
    background-color: @SF_BG_SURFACE@;
    border: 1px solid @SF_BORDER_STRONG@;
    selection-background-color: @SF_BG_RAISED@;
    color: @SF_TEXT_PRIMARY@;
}

QPushButton {
    background-color: @SF_BG_RAISED@;
    border: 1px solid @SF_BORDER_SUBTLE@;
    border-radius: 4px;
    padding: 6px 12px;
    color: @SF_TEXT_SECONDARY@;
}
QPushButton:hover {
    border-color: @SF_BORDER_STRONG@;
    color: @SF_TEXT_PRIMARY@;
}
QPushButton:focus {
    border: 1px solid @SF_ACCENT@;
    color: @SF_TEXT_PRIMARY@;
}
QPushButton#PrimaryButton {
    background-color: @SF_ACCENT_DIM@;
    border: 1px solid @SF_ACCENT@;
    color: @SF_TEXT_PRIMARY@;
}

QFrame#SectionDivider {
    background-color: @SF_BORDER_SUBTLE@;
    border: none;
    max-height: 1px;
}

QPlainTextEdit#CommandLineView {
    background-color: @SF_BG_INSET@;
    border: 1px solid @SF_BORDER_SUBTLE@;
    border-radius: 4px;
    font-family: @SF_FONT_MONO@;
    font-size: 12px;
    color: @SF_TEXT_PRIMARY@;
    padding: 8px;
}

QToolButton#SectionToggle {
    background: transparent;
    border: none;
    color: @SF_TEXT_SECONDARY@;
    padding: 2px 4px;
}
QToolButton#SectionToggle:hover {
    color: @SF_TEXT_PRIMARY@;
}

QTextEdit#RuleBlock {
    background-color: @SF_BG_INSET@;
    border: 1px solid @SF_BORDER_SUBTLE@;
    border-radius: 4px;
    color: @SF_TEXT_PRIMARY@;
    padding: 8px;
}

QFrame#CriticalToast {
    background-color: @SF_BG_RAISED@;
    border: 1px solid @SF_SEV_CRITICAL_FG@;
    border-radius: 6px;
}

QPushButton#LiveButtonActive,
QPushButton#PauseButtonActive {
    background-color: @SF_ACCENT_DIM@;
    border: 1px solid @SF_ACCENT@;
    color: @SF_TEXT_PRIMARY@;
}

QFrame#LiveControlsBar {
    background: transparent;
    border: none;
    max-height: 36px;
}

QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: @SF_BORDER_STRONG@;
    border-radius: 5px;
    min-height: 24px;
}
QScrollBar::handle:vertical:hover {
    background: @SF_SCROLLBAR_HOVER@;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}
QScrollBar:horizontal {
    background: transparent;
    height: 10px;
}
QScrollBar::handle:horizontal {
    background: @SF_BORDER_STRONG@;
    border-radius: 5px;
    min-width: 24px;
}
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
}

QSplitter::handle {
    background-color: @SF_BORDER_SUBTLE@;
}
QSplitter::handle:horizontal {
    width: 1px;
}
QSplitter::handle:vertical {
    height: 1px;
}

QProgressBar {
    background-color: @SF_BG_RAISED@;
    border: none;
    border-radius: 2px;
    height: 4px;
    text-align: center;
}
QProgressBar::chunk {
    background-color: @SF_ACCENT@;
    border-radius: 2px;
}
